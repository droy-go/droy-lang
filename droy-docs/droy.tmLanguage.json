{
  "name": "Droy",
  "scopeName": "source.droy",
  "fileTypes": [".droy"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#ui-components"
    },
    {
      "include": "#events"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#colors"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.droy",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.droy",
          "match": "\\b(set|get|var|func|return|if|else|for|while|print|input|import|export|data|server|setup|tool|bind|ref|watch|emit)\\b"
        },
        {
          "name": "keyword.other.droy",
          "match": "\\b(setup|get_set|value_set|tool_set|group|id|name|tag|attr|selector|query|find|filter|sort)\\b"
        },
        {
          "name": "keyword.operator.droy",
          "match": "\\b(fetch|post|put|delete|patch|ws|http|https)\\b"
        }
      ]
    },
    "ui-components": {
      "patterns": [
        {
          "name": "support.class.component.droy",
          "match": "~[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "events": {
      "patterns": [
        {
          "name": "entity.name.function.event.droy",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.droy",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.droy",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.droy",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.droy",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.droy",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "colors": {
      "patterns": [
        {
          "name": "constant.other.color.rgb-value.droy",
          "match": "#[0-9a-fA-F]{3,8}\\b"
        },
        {
          "name": "constant.other.color.rgb-value.droy",
          "match": "\\b(rgb|rgba|hsl|hsla)\\s*\\([^)]*\\)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.droy",
          "match": "(\\+|-\\*|/|%|==|!=|<=|>=|<|>|&&|\\|\\||!|=|:|=>|\\|>)"
        }
      ]
    }
  }
}
